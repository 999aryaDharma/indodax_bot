# ==============================================================================
# IndoBot Signal (IBS) — Environment Variables
# SALIN file ini → .env lalu isi nilainya.
# JANGAN PERNAH commit file .env ke Git.
# ==============================================================================

# --- Indodax API ---
# Buat di: indodax.com > Pengaturan > API
# WAJIB: Aktifkan HANYA permission "View". JANGAN aktifkan "Trade" atau "Withdraw".
INDODAX_API_KEY=your_indodax_api_key_here
INDODAX_SECRET_KEY=your_indodax_secret_key_here

# --- Telegram ---
# Dapatkan token dari @BotFather. Dapatkan chat_id dari @userinfobot.
TELEGRAM_BOT_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- App (Opsional) ---
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
